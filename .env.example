FMP_API_KEY=
DISCORD_WEBHOOK_URL=
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=20
# MAX_RETRIES is the number of *extra* attempts after the initial request,
# so MAX_RETRIES=3 means up to 4 total HTTP attempts per FMP call.
MAX_RETRIES=3
SEND_DISCLOSURE_ALERTS=true
SEND_CONFIRMATION_ALERT=false
CONFIRMATION_MESSAGE=Congressional trade watcher run complete. Fetched {total_fetched} record(s). Detected {new_records} new disclosure(s).
